{
  "name": "todefine",
  "version": "1.0.0",
  "description": "- Desarrollar y poner en práctica los conocimientos adquiridos en la asignatura a partir del desarrollo de un caso de estudio.",
  "main": "index.js",
  "scripts": {
  "start": "node ./index.js",
  "dev": "node --watch --trace-warnings ./index.js",
  "db:init": "npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all",
  "db:migrate": "npx sequelize-cli db:migrate",
  "db:seed": "npx sequelize-cli db:seed:all",
  "db:reset": "npx sequelize-cli db:migrate:undo:all && npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all",
  "dev:css": "tailwindcss -i ./public/css/main.css -o ./public/css/output.css --watch"
  },
  "repository": {
    "type": "git",
    "url": "todefinied"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "todefinied.com"
  },
  "homepage": "todefinied",
  "dependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "pug": "^3.0.4",
    "sequelize": "^6.37.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "sequelize-cli": "^6.6.5"
  }
}