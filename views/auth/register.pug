extends ../layouts/main.pug

block content
  section.auth-card
    h1 Crear cuenta

    if errors && errors.length
      div.alert.alert-error
        each error in errors
          p= error

    form(action="/auth/register", method="POST")
      div.form-group
        label(for="nickname") Nickname
        input(
          type="text",
          id="nickname",
          name="nickname",
          value=old.nickname || '',
          required
        )

      div.form-group
        label(for="email") Email
        input(
          type="email",
          id="email",
          name="email",
          value=old.email || '',
          required
        )

      div.form-group
        label(for="password") Contraseña
        input(
          type="password",
          id="password",
          name="password",
          required
        )

      div.form-group
        label(for="confirmPassword") Repetir contraseña
        input(
          type="password",
          id="confirmPassword",
          name="confirmPassword",
          required
        )

      button.btn(type="submit") Registrarme

    p
      | ¿Ya tenés cuenta?
      a(href="/auth/login")  Iniciá sesión